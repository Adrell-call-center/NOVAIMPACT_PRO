# ==========================================
# SMTP Configuration
# ==========================================
SMTP_HOST=your-smtp-host.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USERNAME=your-email@domain.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=noreply@domain.com
SMTP_FROM_NAME=Your App Name

# ==========================================
# Database Configuration (PostgreSQL)
# ==========================================
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DATABASE_NAME
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=novaimpact_db
DATABASE_USER=postgres
DATABASE_PASSWORD=your-database-password

# ==========================================
# Theme Configuration
# ==========================================
NEXT_PUBLIC_APP_NAME=Nova Impact
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_THEME_MODE=light
NEXT_PUBLIC_PRIMARY_COLOR=#FFC81A
NEXT_PUBLIC_SECONDARY_COLOR=#FF6584
NEXT_PUBLIC_FONT_FAMILY=Inter
